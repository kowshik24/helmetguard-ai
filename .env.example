APP_NAME=HelmetGuard AI
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_URL=sqlite:///./data/helmetguard.db
REDIS_URL=redis://localhost:6379/0
QUEUE_NAME=helmetguard.jobs
DATA_ROOT=data
UPLOAD_DIR=uploads
ARTIFACTS_DIR=artifacts
REPORTS_DIR=reports
MAX_UPLOAD_MB=500
SIGNED_URL_TTL_SECONDS=3600
DETECTION_CONFIDENCE=0.35
IOU_THRESHOLD=0.5
VIOLATION_COOLDOWN_SECONDS=6
FRAME_SAMPLE_RATE=2
ENABLE_VISION_RUNTIME=true
YOLO_MODEL_PATH=yolov8n.pt
YOLO_USE_BUILTIN_TRACKER=true
YOLO_TRACKER_CONFIG=bytetrack.yaml
TARGET_CLASSES_RAW=person,motorcycle,helmet,license_plate
ENABLE_OCR=true
VIOLATION_EMA_ALPHA=0.35
MIN_VIOLATION_FRAMES=3
MIN_VIOLATION_SCORE=0.55
